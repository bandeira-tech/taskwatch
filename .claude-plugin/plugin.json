{
  "name": "taskwatch",
  "version": "0.0.2",
  "description": "Track what you and your agents are working on — a b3nd protocol where every task and every status update is a URI. The MCP server is a pure b3nd PIN; the skill teaches the protocol shape.",
  "author": {
    "name": "Bandeira Tech",
    "url": "https://github.com/bandeira-tech"
  },
  "homepage": "https://github.com/bandeira-tech/taskwatch",
  "repository": "https://github.com/bandeira-tech/taskwatch",
  "license": "MIT",
  "keywords": ["b3nd", "tasks", "tracking", "agents", "claude-code", "mcp"],
  "mcpServers": {
    "taskwatch": {
      "command": "deno",
      "args": [
        "run",
        "-A",
        "${CLAUDE_PLUGIN_ROOT}/.claude-plugin/mcp-server/mod.ts"
      ],
      "env": {
        "TASKWATCH_DATA": "${TASKWATCH_DATA:-}",
        "TASKWATCH_BACKEND": "${TASKWATCH_BACKEND:-}"
      }
    }
  }
}
